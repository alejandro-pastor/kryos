[Unit]
Description=KryOs - fan/pump curve for NZXT Kraken Z3/2023/2024
Documentation=https://github.com/alejandro-pastor/kryos
After=systemd-tmpfiles-setup.service

[Service]
Type=oneshot
User=root
RuntimeDirectory=kryos
RuntimeDirectoryMode=0750
ExecStart=/usr/local/bin/kryos --once --state /run/kryos/curve.state
MemoryMax=64M
PrivateNetwork=true
NoNewPrivileges=true
ProtectSystem=full
